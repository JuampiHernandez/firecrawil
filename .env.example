FIRECRAWL_API_KEY=fc-your-key

# Optional. If omitted, report generation uses a deterministic fallback report.
AI_GATEWAY_API_KEY=your-ai-gateway-key

# Supabase Auth + cached audits.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key

# Server-side only. Needed for `npm run seed:audits`.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Lemon Squeezy credit checkout.
LEMONSQUEEZY_API_KEY=lsq_your-api-key
LEMONSQUEEZY_STORE_ID=your-store-id
LEMONSQUEEZY_STARTER_VARIANT_ID=your-2-credit-variant-id
LEMONSQUEEZY_GROWTH_VARIANT_ID=your-10-credit-variant-id
LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-signing-secret
